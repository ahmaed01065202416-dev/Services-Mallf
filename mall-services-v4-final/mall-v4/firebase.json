{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": { "rules": "storage.rules" },
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json","**/.*","**/node_modules/**","functions/**","netlify/**","*.md","*.json"],
    "rewrites": [{ "source": "**", "destination": "/index.html" }],
    "headers": [{"source":"/js/**","headers":[{"key":"Cache-Control","value":"public,max-age=86400"}]},
                {"source":"/css/**","headers":[{"key":"Cache-Control","value":"public,max-age=31536000,immutable"}]}]
  }
}
